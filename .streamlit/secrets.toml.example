# ─────────────────────────────────────────────────────────────
# PLANTILLA de credenciales — copia este archivo a secrets.toml
# y rellena SOLO el bloque del backend que quieras usar.
#
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# El archivo real `secrets.toml` está en .gitignore — NUNCA se sube a Git.
# En Streamlit Cloud, pega este contenido en: Advanced settings → Secrets
#
# PRIORIDAD DE BACKEND (data_backend.py):
#   1) Supabase   → si SUPABASE_URL y SUPABASE_KEY están configurados
#   2) SharePoint → si están las credenciales de Azure/Graph
#   3) Excel local (demo) → si no configuras nada
#
# Puedes dejar ambos bloques: Supabase manda mientras esté configurado;
# si lo borras/comentas, la app vuelve sola a SharePoint.
# ─────────────────────────────────────────────────────────────

# ───────── OPCIÓN 1 · Supabase (recomendado para desplegar en Streamlit) ─────────
# PRODUCCIÓN (datos sensibles): SUPABASE_KEY = service_role (acceso a DATOS,
#   solo vive en el servidor) + SUPABASE_ANON_KEY = anon (solo para el LOGIN).
#   Con ese esquema se pueden eliminar las políticas RLS permisivas y una fuga
#   de la clave anon no expone ningún dato (ver sección ENDURECIMIENTO en
#   supabase_schema.sql).
# MVP/pruebas: basta SUPABASE_KEY = anon (requiere las políticas RLS del MVP).
SUPABASE_URL          = "https://xxxxxxxxxxxx.supabase.co"
SUPABASE_KEY          = "xxxxxx...."   # service_role (prod) o anon (MVP)
SUPABASE_ANON_KEY     = "xxxxxx...."   # anon, para el login (opcional si KEY ya es anon)
SUPABASE_TABLE        = "registros_mamposteria"   # opcional; este es el valor por defecto
SUPABASE_TABLE_CONFIG = "config_app"              # opcional; tabla de config editable
SUPABASE_TABLE_SALIDAS = "almacen_salidas"        # opcional; tabla de salidas de almacén
SUPABASE_TABLE_ENTRADAS = "almacen_entradas"      # opcional; tabla de entradas de almacén

# ───────── Acceso y administración (⚠️ IMPORTANTE en producción) ─────────
# ⚠️ SEGURIDAD: si despliegas en público y dejas CORREOS_AUTORIZADOS VACÍO,
#   CUALQUIER persona puede registrarse sola (pestaña "Registrarse") y ver/editar
#   TODOS los datos de la obra. En producción, SIEMPRE define la lista blanca.
#
# CORREOS_AUTORIZADOS: lista blanca de quién puede ENTRAR. Vacío ⇒ acceso ABIERTO
#   a cualquier cuenta registrada. Separa con coma o punto y coma.
# CORREOS_ADMIN: quién puede EDITAR configuración y ELIMINAR registros desde los
#   paneles de admin. Vacío ⇒ se usa CORREOS_AUTORIZADOS; si AMBOS están vacíos,
#   cualquier usuario autenticado es admin (peligroso: podría borrar datos).
#   → Define SIEMPRE este valor en producción.
CORREOS_AUTORIZADOS = "jefe@empresa.com, residente@empresa.com"
CORREOS_ADMIN       = "jefe@empresa.com"

# ───────── OPCIÓN 2 · SharePoint (Microsoft Graph) ─────────
TENANT_ID            = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
CLIENT_ID            = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
CLIENT_SECRET        = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Dominio del tenant de SharePoint (sin https://)
SHAREPOINT_SITE      = "tuempresa.sharepoint.com"

# Nombre del sitio (lo que va después de /sites/)
SHAREPOINT_SITE_NAME = "Construccion"

# Ruta del archivo dentro de la biblioteca de documentos del sitio
SHAREPOINT_FILE_PATH = "Documentos/Mamposteria/datos_mamposteria.xlsx"
